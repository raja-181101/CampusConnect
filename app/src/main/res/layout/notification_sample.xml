<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/openNotification"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/notif_unread_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Unread indicator dot -->
        <View
            android:id="@+id/unreadDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/unread_dot"
            android:visibility="visible"/>

        <!-- Avatar -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/userProfileImg"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/profilepic"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent"
            app:strokeColor="@color/colorPrimary"
            app:strokeWidth="2dp" />

        <!-- Icon badge -->
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="-14dp"
            android:layout_marginTop="28dp"
            android:layout_marginEnd="10dp">

            <ImageView
                android:id="@+id/notifTypeIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/like"
                android:background="@drawable/notif_icon_bg"
                android:padding="4dp"/>
        </RelativeLayout>

        <!-- Text content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/notificationText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp"/>

            <TextView
                android:id="@+id/time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:text="just now"/>
        </LinearLayout>

        <!-- Post thumbnail (for like/comment notifs) -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/postThumb"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            app:shapeAppearance="@style/ShapeAppearanceOverlay.App.CornerSize50Percent"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
